# ===========================================================================
# TBPlan Chat Bot System — environment variables
# ===========================================================================
# Copy to .env.local. For LOCAL DEMO MODE you can leave everything as-is
# (no Supabase / no API key required) and just run `npm run dev`.

# ---------------------------------------------------------------------------
# Mode
# ---------------------------------------------------------------------------
# "true"  = demo mode (local file-backed store + preset admin login)
# "false" = production mode (requires Supabase below)
# unset   = auto (demo unless NEXT_PUBLIC_SUPABASE_URL is set)
NEXT_PUBLIC_DEMO_MODE=true

# Demo admin login (shown on the login screen, pre-filled).
ADMIN_EMAIL=admin@tbplan.mn
ADMIN_PASSWORD=Tbplan@2026
# Secret used to sign the demo session cookie (change for any real use).
AUTH_SECRET=change-this-to-a-long-random-string
# Where the demo store writes its JSON (local dev only).
DATA_DIR=.data

# Public base URL (used by the embed snippet shown in the dashboard).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Max pages a single crawl/sitemap import will fetch.
CRAWL_MAX_PAGES=40

# ---------------------------------------------------------------------------
# AI provider (OPTIONAL in demo mode)
# ---------------------------------------------------------------------------
# Without a key, the demo answers using keyword search over your content.
# With a key, it uses embeddings + the chat model for higher-quality answers.
AI_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini (if AI_PROVIDER=gemini). NOTE: text-embedding-004 is 768-dim — in
# production change vector(1536) -> vector(768) in supabase/schema.sql.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ---------------------------------------------------------------------------
# Supabase (PRODUCTION mode only — set NEXT_PUBLIC_DEMO_MODE=false)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
