# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Project URL + anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by crawl/chat API routes to bypass RLS for writes & retrieval.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# AI provider
# ---------------------------------------------------------------------------
# Which provider to use for embeddings + chat: "openai" (default) or "gemini".
AI_PROVIDER=openai

# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini (used when AI_PROVIDER=gemini)
# NOTE: Gemini embeddings (text-embedding-004) are 768-dim. If you switch to
# Gemini, change vector(1536) -> vector(768) in supabase/schema.sql before
# crawling, and re-crawl so embeddings match.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public base URL of this app (used by the embed snippet shown in the dashboard).
# In local dev this is http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Max pages a single crawl will fetch (keep modest on serverless time limits).
CRAWL_MAX_PAGES=40
